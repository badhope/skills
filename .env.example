# DevFlow Agent Environment Configuration
# Copy this file to DELETE and fill in your values

# Node Environment
NODE_ENV=development

# API Keys (configure via CLI: devflow config provider set-key <platform>)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AI...
# ALIYUN_API_KEY=sk-...
# ZHIPU_API_KEY=...
# DEEPSEEK_API_KEY=sk-...
# SILICONFLOW_API_KEY=sk-...
# BAIDU_API_KEY=<appId>.<secretKey>

# Logging
LOG_LEVEL=info

# Feature Flags
ENABLE_TELEMETRY=false
