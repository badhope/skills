{
  "name": "@devflow/agent",
  "version": "0.1.0",
  "description": "DevFlow Agent CLI - 可靠、诚实、可控的AI开发助手",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "devflow": "./dist/cli.js"
  },
  "scripts": {
    "postinstall": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint -c .eslintrc.cjs src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "ai",
    "cli",
    "agent",
    "devflow",
    "llm",
    "chat",
    "code-review"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/DevFlow-Agent"
  },
  "dependencies": {
    "async-lock": "^1.4.1",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "diff": "^9.0.0",
    "eventemitter3": "^5.0.4",
    "glob": "^13.0.6",
    "graphlib": "^2.1.8",
    "inquirer": "^9.2.15",
    "js-tiktoken": "^1.0.21",
    "lowdb": "^7.0.1",
    "minisearch": "^7.2.0",
    "opossum": "^9.0.0",
    "ora": "^8.2.0",
    "p-retry": "^8.0.0",
    "picocolors": "^1.0.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "reflect-metadata": "^0.2.1",
    "simple-git": "^3.36.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "ts-morph": "^28.0.0",
    "tsyringe": "^4.8.0",
    "uuid": "^14.0.0",
    "wrap-ansi": "^10.0.0",
    "xstate": "^5.31.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/async-lock": "^1.4.2",
    "@types/eslint": "^9.6.1",
    "@types/glob": "^8.1.0",
    "@types/graphlib": "^2.1.12",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/opossum": "^8.1.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "eslint": "^8.57.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
